# ===========================================================================
# Hils Marketing — Frontend environment template
# Copy to `.env` and fill real values. Vite only exposes VITE_* vars to the browser.
# ===========================================================================

# Base URL of the FastAPI backend
VITE_API_BASE_URL=http://localhost:8000

# Stripe (publishable key only — secret key NEVER goes here)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Leaflet / map defaults — centered on Pakistan
VITE_DEFAULT_MAP_CENTER_LAT=30.3753
VITE_DEFAULT_MAP_CENTER_LNG=69.3451
VITE_DEFAULT_MAP_ZOOM=6
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# App
VITE_APP_NAME=Hils Marketing
VITE_DEFAULT_CURRENCY=PKR
