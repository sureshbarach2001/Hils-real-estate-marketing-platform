# ============================================================================
# Hils Marketing — Backend environment template
# Copy to `.env` and fill real values. NEVER commit the real `.env`.
# Loaded automatically by python-dotenv on import of `server.py`.
# ============================================================================

# ---- MongoDB ----
# Local dev:   mongodb://localhost:27017
# Atlas:       mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
DB_NAME=hils_marketing

# ---- JWT (signing) ----
# Generate with: openssl rand -hex 32
# NEVER commit a real value. Rotate every 90 days (see DOCS/security.md).
JWT_SECRET=replace-me-32-byte-hex
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_HOURS=12
JWT_REFRESH_TOKEN_DAYS=7

# ---- Initial admin (seeded on first startup if `users` is empty) ----
# Change the password immediately after first login.
ADMIN_EMAIL=admin@hils.pk
ADMIN_PASSWORD=ChangeMe!OnFirstLogin#2026

# ---- Stripe (test keys only in `.env.example`) ----
STRIPE_API_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=http://localhost:5173/payments/success
STRIPE_CANCEL_URL=http://localhost:5173/payments/cancel

# ---- Email (SMTP) ----
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@hils.pk
SMTP_FROM_NAME=Hils Marketing

# ---- CORS (comma-separated origins) ----
# Production: only the real frontend URL — never `*` (see security.mdc).
CORS_ORIGINS=http://localhost:5173

# ---- Cookies (auth flow) ----
# COOKIE_SAMESITE:
#   lax    — default. Frontend & API share a registrable domain (recommended).
#   strict — also valid; may break OAuth-style redirects.
#   none   — REQUIRED when the frontend is on a different registrable domain
#            than the API (cross-site). Browsers force `Secure` in this mode.
COOKIE_SAMESITE=lax
# COOKIE_SECURE: `true` in prod (forces HTTPS). Default `false` in dev so
# the browser will accept the cookie over plain HTTP localhost.
COOKIE_SECURE=false
# COOKIE_DOMAIN: optional. Set to `.hils.pk` to share cookies across
# subdomains (e.g. www.hils.pk + api.hils.pk). Leave blank in dev.
COOKIE_DOMAIN=

# Trust X-Forwarded-For for client IP detection. Only enable when running
# behind a known reverse proxy (Nginx, Cloudflare, Fly.io, etc.).
TRUST_PROXY_HEADERS=false

# ---- Password reset ----
# How long a password-reset token is valid (minutes). 60 is a sensible default.
RESET_TOKEN_TTL_MINUTES=60

# ---- Rate limiting ----
# Per-(IP, email) lockout on /auth/login is wired in routes/auth.py.
# RATE_LIMIT_AUTH is reserved for a future generic slowapi limiter on /auth/*.
RATE_LIMIT_AUTH=5/15minutes

# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
